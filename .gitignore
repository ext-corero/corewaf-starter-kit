# Customer-supplied configuration (never committed)
config.ini

# Rendered runtime artifacts (output of the templates stage).
# Bundled files (operator-ca.crt, README.md) are explicitly tracked.
runtime/*
!runtime/operator-ca.crt
!runtime/README.md
.runtime/

# Local Docker / orchestrator state
.discover/
discovery.json
hwinfo/

# Compose-time substitutions (DOCKER_GID etc.) — generated per host
.env

# Editor / OS detritus
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
.claude/
