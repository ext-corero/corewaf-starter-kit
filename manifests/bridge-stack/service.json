{
  "version": "0.0.4",
  "service": {
    "name": "corewaf-bridge",
    "description": "Phase 2 bridge stack — caddy-internal (docker-label proxy + ACME), caddy-bridge (operator action listener), alloy (telemetry), valkey (state). Launched by `orchestrator compose up` from the foundation tier (waf/corewaf-starter-kit/compose.yml's `orchestrator` service) once `tunnel` is healthy.",
    "sources": {
      "ghcr.io/ext-corero/waf/caddy-bridge": "tunnel-v0",
      "ghcr.io/ext-corero/services/core/caddy-docker-proxy": "1.0.0",
      "grafana/alloy": "v1.7.5",
      "valkey/valkey": "8"
    },
    "files": [
      "service.json",
      "compose.yml",
      "templates/alloy.tmpl"
    ],
    "variables": {
      "CADDY_BRIDGE_IMAGE": "ghcr.io/ext-corero/waf/caddy-bridge:tunnel-v0",
      "CADDY_INTERNAL_IMAGE": "ghcr.io/ext-corero/services/core/caddy-docker-proxy:1.0.0",
      "ALLOY_IMAGE": "grafana/alloy:v1.7.5",
      "VALKEY_IMAGE": "valkey/valkey:8",
      "TUNNEL_CONTAINER_NAME": "corewaf-tunnel",
      "ADMIN_NETWORK_NAME": "kit-admin"
    },
    "docker": {
      "networks": [],
      "volumes": [
        {"caddy_data": "keep"},
        {"caddy_config": "keep"},
        {"caddy_logs": "keep"},
        {"alloy_data": "keep"},
        {"valkey_data": "keep"}
      ]
    },
    "templates": [
      {
        "source": "templates/alloy.tmpl",
        "destination": "runtime/config.alloy",
        "overwrite": true
      }
    ]
  }
}
