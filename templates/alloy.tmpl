// Rendered by `orchestrator templates render` — do not edit by hand.
// Source: templates/alloy.tmpl
//
// One static, deterministic Alloy config rendered at deploy time from
// customer + discovery inputs. Replaces the previous runtime-discovery
// componentization pattern (see docs/requirements.md §8).

livedebugging {
  enabled = true
}

// ---------------------------------------------------------------------------
// Endpoints — sourced from config.ini, NOT hardcoded.
// ---------------------------------------------------------------------------

prometheus.remote_write "metrics_service" {
  endpoint {
    url = "{{ .Env.MIMIR_URL }}"
  }
}

loki.write "to_loki" {
  endpoint {
    url = "{{ .Env.LOKI_URL }}"
  }
}

// ---------------------------------------------------------------------------
// Self-monitoring
// ---------------------------------------------------------------------------

logging {
  level   = "info"
  format  = "json"
  write_to = [loki.process.alloy_self.receiver]
}

loki.process "alloy_self" {
  forward_to = [loki.write.to_loki.receiver]
  stage.labels {
    values = {
      service_name = "alloy",
      instance     = "{{ .Env.HOSTNAME }}",
      org_scope_id = "{{ .Env.ORG_SCOPE_ID }}",
    }
  }
}

prometheus.exporter.self "alloy_export" {}

prometheus.scrape "alloy_scrape" {
  targets    = prometheus.exporter.self.alloy_export.targets
  forward_to = [prometheus.remote_write.metrics_service.receiver]
}

// ---------------------------------------------------------------------------
// Docker / cAdvisor
// ---------------------------------------------------------------------------

prometheus.exporter.cadvisor "docker" {
  docker_host = "unix:///var/run/docker.sock"
}

prometheus.scrape "cadvisor_scraper" {
  targets    = prometheus.exporter.cadvisor.docker.targets
  forward_to = [prometheus.remote_write.metrics_service.receiver]
}

// ---------------------------------------------------------------------------
// Caddy access + Coraza WAF logs (single rendered block — no runtime imports)
// ---------------------------------------------------------------------------

local.file_match "caddy_logs_dirs" {
  path_targets = [{"__path__" = "/caddy_logs/*.log"}]
}

loki.source.file "caddy_logs" {
  targets    = local.file_match.caddy_logs_dirs.targets
  forward_to = [loki.process.parse_caddy.receiver]
}

loki.process "parse_caddy" {
  forward_to = [loki.write.to_loki.receiver]

  stage.json {
    expressions = {
      level   = "level",
      ts      = "",
      logger  = "",
      msg     = "",
      request = "",
      status  = "",
    }
  }
  stage.timestamp {
    source = "ts"
    format = "Unix"
  }
  stage.labels {
    values = {
      level        = "",
      logger       = "",
      status       = "",
      service_name = "caddy",
      instance     = "{{ .Env.HOSTNAME }}",
      org_scope_id = "{{ .Env.ORG_SCOPE_ID }}",
    }
  }
}
