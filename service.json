{
  "version": "0.1.0",
  "service": {
    "name": "corewaf-starter-kit",
    "description": "Customer-facing CoreWAF kit. v2 Phase 1 ships the foundation tier only (Network Loader image: init + tunnel). Phase 2 will add the orchestrator handoff that launches the bridge stack from a manifest.",
    "sources": {
      "ghcr.io/ext-corero/waf/network-loader": "latest",
      "ghcr.io/ext-corero/waf/orchestrator": "latest",
      "ghcr.io/ext-corero/waf/caddy-bridge": "tunnel-v0",
      "ghcr.io/ext-corero/waf/caddy-waf": "latest",
      "valkey/valkey": "8",
      "grafana/alloy": "v1.7.5"
    },
    "files": [
      "service.json",
      "compose.yml",
      "config.ini.example",
      "bootstrap.sh",
      "scripts/install.sh",
      "kit-version.json",
      "network.json"
    ],
    "variables": {
      "INSTANCE_COMMENT": "${instance_comment}"
    },
    "docker": {
      "networks": [
        {
          "corewaf-edge": "bridge"
        },
        {
          "corewaf-internal": "bridge"
        }
      ],
      "volumes": [
        {
          "tunnel_state": "keep"
        },
        {
          "caddy_data": "keep"
        },
        {
          "caddy_config": "keep"
        },
        {
          "caddy_logs": "keep"
        },
        {
          "alloy_data": "keep"
        },
        {
          "valkey_data": "keep"
        }
      ]
    },
    "templates": []
  }
}
